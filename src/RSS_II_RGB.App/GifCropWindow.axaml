<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RSS_II_RGB.App"
        x:Class="RSS_II_RGB.App.GifCropWindow"
        Icon="/Assets/Mainicon.ico"
        Title="{x:Static vm:L.GifCropTitle}"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="{x:Static vm:L.GifCropHint}" TextWrapping="Wrap" Opacity="0.8" MaxWidth="820"/>

        <Border BorderBrush="#33888888" BorderThickness="1" CornerRadius="4" HorizontalAlignment="Left">
            <Canvas x:Name="CropSurface" Background="#22000000"
                    PointerPressed="OnSurfacePointerPressed"
                    PointerMoved="OnSurfacePointerMoved"
                    PointerReleased="OnSurfacePointerReleased">
                <Image x:Name="PreviewImage" Stretch="Fill"/>
                <Rectangle x:Name="CropRect" IsHitTestVisible="False"
                           Fill="#3300AAFF" Stroke="#FF00AAFF" StrokeThickness="2"/>
                <Rectangle x:Name="HandleTL" Width="10" Height="10" IsHitTestVisible="False"
                           Fill="#FFFFFFFF" Stroke="#FF00AAFF" StrokeThickness="1"/>
                <Rectangle x:Name="HandleTR" Width="10" Height="10" IsHitTestVisible="False"
                           Fill="#FFFFFFFF" Stroke="#FF00AAFF" StrokeThickness="1"/>
                <Rectangle x:Name="HandleBL" Width="10" Height="10" IsHitTestVisible="False"
                           Fill="#FFFFFFFF" Stroke="#FF00AAFF" StrokeThickness="1"/>
                <Rectangle x:Name="HandleBR" Width="10" Height="10" IsHitTestVisible="False"
                           Fill="#FFFFFFFF" Stroke="#FF00AAFF" StrokeThickness="1"/>
            </Canvas>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="{x:Static vm:L.GifCropCancel}" Click="OnCancel"/>
            <Button Content="{x:Static vm:L.GifCropOk}" Click="OnOk"/>
        </StackPanel>
    </StackPanel>
</Window>
