<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RSS_II_RGB.App"
        x:Class="RSS_II_RGB.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/Mainicon.ico"
        Title="Strix Scope II RGB"
        Width="540" Height="640"
        MinWidth="460" MinHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="14">
            <TextBlock Text="Strix Scope II RGB" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.8"/>

            <TextBlock Text="Effect" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Effects}"
                      SelectedItem="{Binding SelectedEffect}"
                      HorizontalAlignment="Stretch"
                      IsEnabled="{Binding IsConnected}"/>

            <TextBlock Text="Overlays" FontWeight="SemiBold"/>
            <CheckBox Content="Reactive — keypress flare + ripple"
                      IsChecked="{Binding EnableReactive}" IsEnabled="{Binding IsConnected}"/>
            <CheckBox Content="Audio — frequency spectrum"
                      IsChecked="{Binding EnableAudio}" IsEnabled="{Binding IsConnected}"/>
            <TextBlock Text="Reactive sits above audio; system metrics sit above both."
                       Opacity="0.6" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding BrightnessPercent, StringFormat='Brightness: {0:0}%'}" FontWeight="SemiBold"/>
            <Slider Minimum="0" Maximum="100" Value="{Binding BrightnessPercent}" IsEnabled="{Binding IsConnected}"/>

            <TextBlock Text="{Binding AudioSensitivity, StringFormat='Audio sensitivity: {0:0.0}×'}" FontWeight="SemiBold"/>
            <Slider Minimum="0.5" Maximum="4" Value="{Binding AudioSensitivity}" IsEnabled="{Binding IsConnected}"/>

            <TextBlock Text="Colour" FontWeight="SemiBold"/>
            <ColorPicker Color="{Binding PickedColor}" IsEnabled="{Binding IsConnected}" HorizontalAlignment="Left"/>
            <WrapPanel Orientation="Horizontal">
                <Button Content="Red"     Command="{Binding SetColorCommand}" CommandParameter="FF0000" Margin="0,0,6,6"/>
                <Button Content="Green"   Command="{Binding SetColorCommand}" CommandParameter="00FF00" Margin="0,0,6,6"/>
                <Button Content="Blue"    Command="{Binding SetColorCommand}" CommandParameter="0066FF" Margin="0,0,6,6"/>
                <Button Content="Cyan"    Command="{Binding SetColorCommand}" CommandParameter="00FF66" Margin="0,0,6,6"/>
                <Button Content="Magenta" Command="{Binding SetColorCommand}" CommandParameter="FF00FF" Margin="0,0,6,6"/>
                <Button Content="White"   Command="{Binding SetColorCommand}" CommandParameter="FFFFFF" Margin="0,0,6,6"/>
            </WrapPanel>

            <Button Content="Zone editor…" Click="OnOpenZoneEditor"
                    IsEnabled="{Binding IsConnected}" HorizontalAlignment="Left"/>

            <CheckBox Content="Start with Windows (minimised to tray)"
                      IsChecked="{Binding StartWithWindows}"/>

            <Expander Header="System metrics (overlay)" IsEnabled="{Binding IsConnected}">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <CheckBox Content="Show metric bars on the keyboard" IsChecked="{Binding ShowMetrics}"/>
                    <TextBlock Text="Layout" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding MetricLayoutOptions}" SelectedItem="{Binding MetricLayout}"
                              HorizontalAlignment="Stretch"/>
                    <TextBlock Text="Utilisation % thresholds (→ 1 / 2 / 3 / 4 cells)" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Value="{Binding Pct1}" Minimum="0" Maximum="100" Width="130"/>
                        <NumericUpDown Value="{Binding Pct2}" Minimum="0" Maximum="100" Width="130"/>
                        <NumericUpDown Value="{Binding Pct3}" Minimum="0" Maximum="100" Width="130"/>
                    </StackPanel>
                    <TextBlock Text="GPU temperature °C thresholds" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Value="{Binding Temp1}" Minimum="0" Maximum="120" Width="130"/>
                        <NumericUpDown Value="{Binding Temp2}" Minimum="0" Maximum="120" Width="130"/>
                        <NumericUpDown Value="{Binding Temp3}" Minimum="0" Maximum="120" Width="130"/>
                    </StackPanel>
                    <TextBlock Text="CPU%→first group, Mem%→second, GPU%→third, GPU temp→last."
                               Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <TextBlock Text="Tip: tick 'Reactive' and type — each key flares and ripples on top of your effect."
                       Opacity="0.6" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>
