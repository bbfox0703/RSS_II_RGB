<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RSS_II_RGB.App"
        x:Class="RSS_II_RGB.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/Mainicon.ico"
        Title="Strix Scope II RGB"
        Width="540" Height="640"
        MinWidth="460" MinHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer>
        <StackPanel Margin="22" Spacing="14">
            <TextBlock Text="Strix Scope II RGB" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.8"/>

            <TextBlock Text="{x:Static vm:L.EffectLabel}" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Effects}"
                      SelectedItem="{Binding SelectedEffect}"
                      HorizontalAlignment="Stretch"
                      IsEnabled="{Binding IsConnected}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:EffectChoice">
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{x:Static vm:L.OverlaysLabel}" FontWeight="SemiBold"/>
            <CheckBox Content="{x:Static vm:L.ReactiveOverlay}"
                      IsChecked="{Binding EnableReactive}" IsEnabled="{Binding IsConnected}"/>
            <CheckBox Content="{x:Static vm:L.AudioOverlay}"
                      IsChecked="{Binding EnableAudio}" IsEnabled="{Binding IsConnected}"/>
            <TextBlock Text="{x:Static vm:L.AudioLayoutLabel}" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding AudioLayoutOptions}" SelectedItem="{Binding AudioLayout}"
                      HorizontalAlignment="Stretch" IsEnabled="{Binding EnableAudio}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:AudioLayoutChoice">
                        <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{x:Static vm:L.PriorityHint}"
                       Opacity="0.6" TextWrapping="Wrap"/>

            <TextBlock Text="{Binding BrightnessText}" FontWeight="SemiBold"/>
            <Slider Minimum="0" Maximum="100" Value="{Binding BrightnessPercent}" IsEnabled="{Binding IsConnected}"/>

            <TextBlock Text="{Binding AudioSensitivityText}" FontWeight="SemiBold"/>
            <Slider Minimum="0.5" Maximum="4" Value="{Binding AudioSensitivity}" IsEnabled="{Binding IsConnected}"/>

            <TextBlock Text="{Binding AudioBarsMultiplierText}" FontWeight="SemiBold"
                       IsVisible="{Binding IsAudioBarsLayout}"/>
            <Slider Minimum="0.5" Maximum="2" Value="{Binding AudioBarsMultiplier}"
                    IsEnabled="{Binding IsConnected}" IsVisible="{Binding IsAudioBarsLayout}"/>

            <TextBlock Text="{x:Static vm:L.ColourLabel}" FontWeight="SemiBold"/>
            <ColorPicker Color="{Binding PickedColor}" IsEnabled="{Binding IsConnected}" HorizontalAlignment="Left"/>
            <WrapPanel Orientation="Horizontal">
                <Button Content="{x:Static vm:L.ColorRed}"     Command="{Binding SetColorCommand}" CommandParameter="FF0000" Margin="0,0,6,6"/>
                <Button Content="{x:Static vm:L.ColorGreen}"   Command="{Binding SetColorCommand}" CommandParameter="00FF00" Margin="0,0,6,6"/>
                <Button Content="{x:Static vm:L.ColorBlue}"    Command="{Binding SetColorCommand}" CommandParameter="0066FF" Margin="0,0,6,6"/>
                <Button Content="{x:Static vm:L.ColorCyan}"    Command="{Binding SetColorCommand}" CommandParameter="00FF66" Margin="0,0,6,6"/>
                <Button Content="{x:Static vm:L.ColorMagenta}" Command="{Binding SetColorCommand}" CommandParameter="FF00FF" Margin="0,0,6,6"/>
                <Button Content="{x:Static vm:L.ColorWhite}"   Command="{Binding SetColorCommand}" CommandParameter="FFFFFF" Margin="0,0,6,6"/>
            </WrapPanel>

            <Button Content="{x:Static vm:L.ZoneEditorButton}" Click="OnOpenZoneEditor"
                    IsEnabled="{Binding IsConnected}" HorizontalAlignment="Left"/>

            <CheckBox Content="{x:Static vm:L.StartWithWindows}"
                      IsChecked="{Binding StartWithWindows}"/>

            <Expander Header="{x:Static vm:L.SystemMetricsHeader}" IsEnabled="{Binding IsConnected}">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <CheckBox Content="{x:Static vm:L.ShowMetricBars}" IsChecked="{Binding ShowMetrics}"/>
                    <TextBlock Text="{x:Static vm:L.LayoutLabel}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding MetricLayoutOptions}" SelectedItem="{Binding MetricLayout}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:MetricLayoutChoice">
                                <TextBlock Text="{Binding Converter={x:Static vm:EnumDisplayConverter.Instance}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{x:Static vm:L.UtilisationThresholds}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Value="{Binding Pct1}" Minimum="0" Maximum="100" Width="130"/>
                        <NumericUpDown Value="{Binding Pct2}" Minimum="0" Maximum="100" Width="130"/>
                        <NumericUpDown Value="{Binding Pct3}" Minimum="0" Maximum="100" Width="130"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static vm:L.GpuTempThresholds}" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <NumericUpDown Value="{Binding Temp1}" Minimum="0" Maximum="120" Width="130"/>
                        <NumericUpDown Value="{Binding Temp2}" Minimum="0" Maximum="120" Width="130"/>
                        <NumericUpDown Value="{Binding Temp3}" Minimum="0" Maximum="120" Width="130"/>
                    </StackPanel>
                    <TextBlock Text="{x:Static vm:L.MetricMappingHint}"
                               Opacity="0.6" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>

            <TextBlock Text="{x:Static vm:L.MainTip}"
                       Opacity="0.6" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>
